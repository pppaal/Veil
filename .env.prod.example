# VEIL production environment template.
# Copy to .env.prod and fill in. Never commit .env.prod.

# ---- Public hostnames ----
# Caddy issues TLS for both. They MUST resolve to the VPS public IP.
CADDY_PUBLIC_HOSTNAME=veil.example.com
CADDY_S3_HOSTNAME=s3.veil.example.com
ACME_EMAIL=ops@example.com

# Origin the API trusts for CORS. Same as CADDY_PUBLIC_HOSTNAME, with scheme.
VEIL_ALLOWED_ORIGINS=https://veil.example.com
# Public S3 endpoint that browsers/phones use for presigned PUTs.
VEIL_S3_PUBLIC_ENDPOINT=https://s3.veil.example.com

# ---- Postgres ----
POSTGRES_DB=veil
POSTGRES_USER=veil
# openssl rand -base64 32
POSTGRES_PASSWORD=replace-me

# ---- Redis ----
# openssl rand -base64 32
REDIS_PASSWORD=replace-me

# ---- MinIO ----
MINIO_ROOT_USER=replace-me-min-12-chars
# openssl rand -base64 32
MINIO_ROOT_PASSWORD=replace-me-min-32-chars
MINIO_BUCKET=veil-encrypted

# ---- API ----
# openssl rand -base64 32
VEIL_JWT_SECRET=replace-me
VEIL_JWT_AUDIENCE=veil-mobile
VEIL_JWT_ISSUER=veil-api
VEIL_LOG_LEVEL=info
VEIL_S3_REGION=us-east-1

# Production gate. MUST stay false until external crypto audit clears
# the LibCryptoAdapter and external-review-remediation-tracker is empty.
# Setting this to true otherwise is a policy violation.
VEIL_AUDITED_CRYPTO_ATTESTED=false

# Push delivery — disabled in private beta. Set to a valid provider once
# APNs/FCM credentials and the privacy review have shipped.
VEIL_PUSH_PROVIDER=none
VEIL_PUSH_ENABLE_DELIVERY=false

# ---- Metrics ----
# Bearer token for /v1/metrics scrape. Empty disables the endpoint.
# openssl rand -hex 24
VEIL_METRICS_AUTH_TOKEN=replace-me

# ---- Grafana ----
# openssl rand -base64 24
GRAFANA_ADMIN_PASSWORD=replace-me

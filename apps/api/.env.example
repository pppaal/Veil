VEIL_ENV=development
VEIL_API_PORT=3000
VEIL_DATABASE_URL=postgresql://veil:veil@localhost:5432/veil
VEIL_REDIS_URL=redis://localhost:6379
VEIL_S3_ENDPOINT=http://localhost:9000
VEIL_S3_REGION=us-east-1
VEIL_S3_ACCESS_KEY=minioadmin
VEIL_S3_SECRET_KEY=minioadmin
VEIL_S3_BUCKET=veil-encrypted
VEIL_JWT_SECRET=replace-me-with-openssl-rand-base64-32-bytes
VEIL_JWT_AUDIENCE=veil-mobile
VEIL_JWT_ISSUER=veil-api
# Push: none | apns | fcm | unifiedpush
VEIL_PUSH_PROVIDER=none
VEIL_PUSH_ENABLE_DELIVERY=false
# UnifiedPush (Google-free, F-Droid path). The device's distributor endpoint is
# the token — no server credentials. STRONGLY recommend an allowlist in prod to
# close SSRF/DNS-rebinding. See docs/unifiedpush-fdroid.md.
VEIL_UNIFIEDPUSH_ALLOWED_HOSTS=
VEIL_APNS_BUNDLE_ID=
VEIL_APNS_TEAM_ID=
VEIL_APNS_KEY_ID=
VEIL_APNS_PRIVATE_KEY_PEM=
VEIL_APNS_USE_SANDBOX=true
VEIL_FCM_PROJECT_ID=
VEIL_FCM_SERVICE_ACCOUNT_JSON=
VEIL_LOG_LEVEL=info
VEIL_TRANSFER_TOKEN_TTL_SECONDS=300
VEIL_AUTH_CHALLENGE_TTL_SECONDS=120
# Metadata retention: terminal call records older than this are swept from the
# server (clients keep their own call log). 0 = retain forever. Default 30.
VEIL_CALL_RECORD_RETENTION_DAYS=30
# Consumed X3DH one-time prekeys older than this are pruned (unconsumed pool
# prekeys are never touched). 0 = retain forever. Default 30.
VEIL_PREKEY_CONSUMED_RETENTION_DAYS=30

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("VEIL_DATABASE_URL")
}

enum UserStatus {
  active
  locked
  revoked
}

enum DevicePlatform {
  ios
  android
  windows
  macos
  linux
}

enum ConversationType {
  direct
  group
  channel
}

enum MessageType {
  text
  image
  file
  system
  voice
  sticker
  reaction
  call
}

enum MemberRole {
  owner
  admin
  member
  subscriber
}

enum CallType {
  voice
  video
}

enum CallStatus {
  ringing
  active
  ended
  missed
  declined
}

enum StoryContentType {
  text
  image
  video
}

enum AttachmentUploadStatus {
  pending
  uploaded
  failed
}

model User {
  id               String               @id @default(uuid()) @db.Uuid
  handle           String               @unique @db.VarChar(32)
  displayName      String?              @map("display_name") @db.VarChar(80)
  avatarPath       String?              @map("avatar_path")
  status           UserStatus           @default(active)
  activeDeviceId   String?              @map("active_device_id") @db.Uuid
  createdAt        DateTime             @default(now()) @map("created_at")
  updatedAt        DateTime             @updatedAt @map("updated_at")
  devices          Device[]             @relation("UserDevices")
  activeDevice     Device?              @relation("ActiveDevice", fields: [activeDeviceId], references: [id], onDelete: SetNull)
  conversationRefs ConversationMember[]
  receipts         MessageReceipt[]
  transferSessions DeviceTransferSession[]
  profile          UserProfile?
  contacts         UserContact[]          @relation("UserContacts")
  contactOf        UserContact[]          @relation("UserContactOf")
  createdGroups    GroupMeta[]
  createdChannels  ChannelMeta[]
  stories          Story[]
  storyViews       StoryView[]
  reactions        Reaction[]
  blocksOutgoing   UserBlock[]            @relation("BlocksOutgoing")
  blocksIncoming   UserBlock[]            @relation("BlocksIncoming")
  conversationMutes ConversationMute[]
  reportsFiled     AbuseReport[]          @relation("ReportsFiled")
  reportsAgainst   AbuseReport[]          @relation("ReportsAgainst")

  @@index([activeDeviceId])
  @@map("users")
}

model UserBlock {
  blockerUserId String   @map("blocker_user_id") @db.Uuid
  blockedUserId String   @map("blocked_user_id") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at")
  blocker       User     @relation("BlocksOutgoing", fields: [blockerUserId], references: [id], onDelete: Cascade)
  blocked       User     @relation("BlocksIncoming", fields: [blockedUserId], references: [id], onDelete: Cascade)

  @@id([blockerUserId, blockedUserId])
  @@index([blockedUserId])
  @@map("user_blocks")
}

model ConversationMute {
  userId         String    @map("user_id") @db.Uuid
  conversationId String    @map("conversation_id") @db.Uuid
  // null = muted indefinitely. A future date = auto-unmutes after that time.
  mutedUntil     DateTime? @map("muted_until")
  createdAt      DateTime  @default(now()) @map("created_at")
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@id([userId, conversationId])
  @@index([conversationId])
  @@map("conversation_mutes")
}

model AbuseReport {
  id              String   @id @default(uuid()) @db.Uuid
  reporterUserId  String   @map("reporter_user_id") @db.Uuid
  reportedUserId  String   @map("reported_user_id") @db.Uuid
  conversationId  String?  @map("conversation_id") @db.Uuid
  messageId       String?  @map("message_id") @db.Uuid
  reason          String   @db.VarChar(40)
  note            String?  @db.VarChar(1000)
  createdAt       DateTime @default(now()) @map("created_at")
  reporter        User     @relation("ReportsFiled", fields: [reporterUserId], references: [id], onDelete: Cascade)
  reported        User     @relation("ReportsAgainst", fields: [reportedUserId], references: [id], onDelete: Cascade)

  @@index([reportedUserId, createdAt])
  @@index([reporterUserId, createdAt])
  @@map("abuse_reports")
}

model Device {
  id                String                  @id @default(uuid()) @db.Uuid
  userId            String                  @map("user_id") @db.Uuid
  platform          DevicePlatform
  deviceName        String                  @map("device_name") @db.VarChar(80)
  publicIdentityKey String                  @map("public_identity_key")
  signedPrekeyBundle String                 @map("signed_prekey_bundle")
  authPublicKey     String                  @map("auth_public_key")
  pushToken         String?                 @map("push_token")
  isActive          Boolean                 @default(true) @map("is_active")
  revokedAt         DateTime?               @map("revoked_at")
  trustedAt         DateTime                @default(now()) @map("trusted_at")
  joinedFromDeviceId String?                @map("joined_from_device_id") @db.Uuid
  createdAt         DateTime                @default(now()) @map("created_at")
  lastSeenAt        DateTime                @default(now()) @map("last_seen_at")
  lastSyncAt        DateTime?               @map("last_sync_at")
  user              User                    @relation("UserDevices", fields: [userId], references: [id], onDelete: Cascade)
  activeForUsers    User[]                  @relation("ActiveDevice")
  sentMessages      Message[]
  attachments       Attachment[]
  oldTransferSessions DeviceTransferSession[] @relation("OldDeviceTransfer")
  joinedFromDevice  Device?                 @relation("JoinedDeviceGraph", fields: [joinedFromDeviceId], references: [id], onDelete: SetNull)
  joinedDevices     Device[]                @relation("JoinedDeviceGraph")
  conversationStates DeviceConversationState[]
  initiatedCalls     CallRecord[]

  @@index([userId, isActive])
  @@index([joinedFromDeviceId])
  @@map("devices")
}

model Conversation {
  id        String               @id @default(uuid()) @db.Uuid
  type      ConversationType     @default(direct)
  createdAt DateTime             @default(now()) @map("created_at")
  // Per-conversation default TTL for new messages, in seconds. null = off.
  // Client uses this to auto-stamp expiresAt on outgoing messages, and
  // server enforces it as an upper bound on incoming messages.
  disappearingTimerSeconds Int?  @map("disappearing_timer_seconds")
  members      ConversationMember[]
  messages     Message[]
  deviceStates DeviceConversationState[]
  groupMeta    GroupMeta?
  channelMeta  ChannelMeta?
  callRecords  CallRecord[]
  mutes        ConversationMute[]

  @@map("conversations")
}

model ConversationMember {
  id             String        @id @default(uuid()) @db.Uuid
  conversationId String        @map("conversation_id") @db.Uuid
  userId         String        @map("user_id") @db.Uuid
  role           MemberRole    @default(member)
  joinedAt       DateTime      @default(now()) @map("joined_at")
  conversation   Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
  @@map("conversation_members")
}

model DeviceConversationState {
  id                        String       @id @default(uuid()) @db.Uuid
  deviceId                  String       @map("device_id") @db.Uuid
  conversationId            String       @map("conversation_id") @db.Uuid
  lastSyncedConversationOrder Int?       @map("last_synced_conversation_order")
  lastReadConversationOrder Int?         @map("last_read_conversation_order")
  updatedAt                 DateTime     @updatedAt @map("updated_at")
  device                    Device       @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  conversation              Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([deviceId, conversationId])
  @@index([deviceId, updatedAt])
  @@index([conversationId, updatedAt])
  @@map("device_conversation_states")
}

model Message {
  id               String        @id @default(uuid()) @db.Uuid
  conversationId   String        @map("conversation_id") @db.Uuid
  senderDeviceId   String        @map("sender_device_id") @db.Uuid
  clientMessageId  String        @map("client_message_id") @db.VarChar(80)
  conversationOrder Int         @map("conversation_order")
  ciphertext       String
  nonce            String
  messageType      MessageType   @map("message_type")
  attachmentId     String?       @map("attachment_id") @db.Uuid
  attachmentRef    Json?         @map("attachment_ref")
  serverReceivedAt DateTime      @default(now()) @map("server_received_at")
  deletedAt        DateTime?     @map("deleted_at")
  expiresAt        DateTime?     @map("expires_at")
  conversation     Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderDevice     Device        @relation(fields: [senderDeviceId], references: [id], onDelete: Restrict)
  attachment       Attachment?   @relation(fields: [attachmentId], references: [id], onDelete: SetNull)
  receipts         MessageReceipt[]
  reactions        Reaction[]

  @@unique([senderDeviceId, clientMessageId])
  @@index([conversationId, conversationOrder])
  @@index([conversationId, serverReceivedAt])
  @@index([attachmentId])
  @@map("messages")
}

model MessageReceipt {
  id          String    @id @default(uuid()) @db.Uuid
  messageId   String    @map("message_id") @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  deliveredAt DateTime? @map("delivered_at")
  readAt      DateTime? @map("read_at")
  message     Message   @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([userId])
  @@map("message_receipts")
}

model Attachment {
  id               String                 @id @default(uuid()) @db.Uuid
  uploaderDeviceId String                 @map("uploader_device_id") @db.Uuid
  storageKey       String                 @map("storage_key")
  contentType      String                 @map("content_type")
  sizeBytes        Int                    @map("size_bytes")
  sha256           String
  uploadStatus     AttachmentUploadStatus @default(pending) @map("upload_status")
  createdAt        DateTime               @default(now()) @map("created_at")
  uploaderDevice   Device                 @relation(fields: [uploaderDeviceId], references: [id], onDelete: Restrict)
  messages         Message[]

  @@index([uploaderDeviceId, createdAt])
  @@index([storageKey])
  @@map("attachments")
}

model DeviceTransferSession {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  oldDeviceId String    @map("old_device_id") @db.Uuid
  tokenHash   String    @map("token_hash")
  expiresAt   DateTime  @map("expires_at")
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  oldDevice   Device    @relation("OldDeviceTransfer", fields: [oldDeviceId], references: [id], onDelete: Restrict)

  @@index([userId, expiresAt])
  @@index([oldDeviceId])
  @@map("device_transfer_sessions")
}

model GroupMeta {
  id              String       @id @default(uuid()) @db.Uuid
  conversationId  String       @unique @map("conversation_id") @db.Uuid
  name            String       @db.VarChar(120)
  description     String?      @db.VarChar(500)
  avatarPath      String?      @map("avatar_path")
  createdByUserId String       @map("created_by_user_id") @db.Uuid
  isPublic        Boolean      @default(false) @map("is_public")
  memberLimit     Int          @default(500) @map("member_limit")
  link            String?      @unique @db.VarChar(120)
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  createdBy       User         @relation(fields: [createdByUserId], references: [id], onDelete: Restrict)

  @@index([createdByUserId])
  @@map("group_metas")
}

model ChannelMeta {
  id              String       @id @default(uuid()) @db.Uuid
  conversationId  String       @unique @map("conversation_id") @db.Uuid
  name            String       @db.VarChar(120)
  description     String?      @db.VarChar(500)
  avatarPath      String?      @map("avatar_path")
  createdByUserId String       @map("created_by_user_id") @db.Uuid
  isPublic        Boolean      @default(false) @map("is_public")
  subscriberCount Int          @default(0) @map("subscriber_count")
  link            String?      @unique @db.VarChar(120)
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  createdBy       User         @relation(fields: [createdByUserId], references: [id], onDelete: Restrict)

  @@index([createdByUserId])
  @@map("channel_metas")
}

model UserContact {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  contactUserId String   @map("contact_user_id") @db.Uuid
  nickname      String?  @db.VarChar(80)
  createdAt     DateTime @default(now()) @map("created_at")
  user          User     @relation("UserContacts", fields: [userId], references: [id], onDelete: Cascade)
  contactUser   User     @relation("UserContactOf", fields: [contactUserId], references: [id], onDelete: Cascade)

  @@unique([userId, contactUserId])
  @@index([contactUserId])
  @@map("user_contacts")
}

model UserProfile {
  id            String    @id @default(uuid()) @db.Uuid
  userId        String    @unique @map("user_id") @db.Uuid
  bio           String?   @db.VarChar(300)
  statusMessage String?   @map("status_message") @db.VarChar(140)
  statusEmoji   String?   @map("status_emoji") @db.VarChar(8)
  lastStatusAt  DateTime? @map("last_status_at")
  avatarPath    String?   @map("avatar_path")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model Story {
  id          String           @id @default(uuid()) @db.Uuid
  userId      String           @map("user_id") @db.Uuid
  contentType StoryContentType @map("content_type")
  contentUrl  String           @map("content_url")
  caption     String?          @db.VarChar(300)
  expiresAt   DateTime         @map("expires_at")
  viewCount   Int              @default(0) @map("view_count")
  createdAt   DateTime         @default(now()) @map("created_at")
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  views       StoryView[]

  @@index([userId, createdAt])
  @@index([expiresAt])
  @@map("stories")
}

model StoryView {
  id           String   @id @default(uuid()) @db.Uuid
  storyId      String   @map("story_id") @db.Uuid
  viewerUserId String   @map("viewer_user_id") @db.Uuid
  viewedAt     DateTime @default(now()) @map("viewed_at")
  story        Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  viewer       User     @relation(fields: [viewerUserId], references: [id], onDelete: Cascade)

  @@unique([storyId, viewerUserId])
  @@index([viewerUserId])
  @@map("story_views")
}

model Reaction {
  id        String   @id @default(uuid()) @db.Uuid
  messageId String   @map("message_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  emoji     String   @db.VarChar(32)
  createdAt DateTime @default(now()) @map("created_at")
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([userId])
  @@map("reactions")
}

model CallRecord {
  id                String       @id @default(uuid()) @db.Uuid
  conversationId    String       @map("conversation_id") @db.Uuid
  initiatorDeviceId String       @map("initiator_device_id") @db.Uuid
  callType          CallType     @map("call_type")
  status            CallStatus   @default(ringing)
  startedAt         DateTime     @default(now()) @map("started_at")
  endedAt           DateTime?    @map("ended_at")
  duration          Int?
  conversation      Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  initiatorDevice   Device       @relation(fields: [initiatorDeviceId], references: [id], onDelete: Restrict)

  @@index([conversationId, startedAt])
  @@index([initiatorDeviceId])
  @@map("call_records")
}

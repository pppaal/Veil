{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "type": "stat",
      "title": "API uptime",
      "id": 1,
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [{ "expr": "up{job=\"veil-api\"}", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ]
        }
      }
    },
    {
      "type": "stat",
      "title": "Active WS connections",
      "id": 2,
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [{ "expr": "veil_ws_connections_active", "refId": "A" }]
    },
    {
      "type": "timeseries",
      "title": "HTTP requests / second by status class",
      "id": 3,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "sum by (status_class) (rate(veil_http_requests_total[1m]))",
          "legendFormat": "{{ status_class }}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "p50 / p95 latency by route",
      "id": 4,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum by (le, route_class) (rate(veil_http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p50 {{ route_class }}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, route_class) (rate(veil_http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p95 {{ route_class }}",
          "refId": "B"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Messages sent / minute",
      "id": 5,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "sum by (message_type) (rate(veil_messages_sent_total[1m])) * 60",
          "legendFormat": "{{ message_type }}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Auth events / minute",
      "id": 6,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "sum by (kind) (rate(veil_auth_events_total[1m])) * 60",
          "legendFormat": "{{ kind }}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Process memory (RSS)",
      "id": 7,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "targets": [
        {
          "expr": "process_resident_memory_bytes{job=\"veil-api\"}",
          "legendFormat": "rss",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "type": "timeseries",
      "title": "Event loop lag (Node)",
      "id": 8,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "targets": [
        {
          "expr": "veil_nodejs_eventloop_lag_seconds",
          "legendFormat": "lag",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    }
  ],
  "schemaVersion": 39,
  "tags": ["veil"],
  "templating": { "list": [] },
  "time": { "from": "now-3h", "to": "now" },
  "timezone": "browser",
  "title": "VEIL — Production Overview",
  "uid": "veil-prod",
  "version": 1,
  "weekStart": ""
}
